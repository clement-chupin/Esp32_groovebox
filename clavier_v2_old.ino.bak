// ============================================================
//  HELPERS
// ============================================================
float applyOctave(float hz, int8_t oct) {
  if (oct > 0) { for (int8_t i = 0; i < oct;  i++) hz *= 2.0f; }
  else         { for (int8_t i = 0; i > oct;  i--) hz *= 0.5f; }
  return constrain(hz, 20.0f, 6000.0f);
}

float keyToFreqColumnOrder(int key) {
  const float rootHz = 261.63f; // C4
  int row = key / COLS;
  int col = key % COLS;
  int semitone = col * 4 + row;
  float hz = rootHz * powf(2.0f, (float)semitone / 12.0f);
  return applyOctave(hz, octaveShift);
}

int8_t quantizeOctaveFromPot(int potValue) {
  int v = constrain(potValue, 0, 4095);
  if (v < 585) return -4;
  if (v < 1170) return -3;
  if (v < 1755) return -2;
  if (v < 2340) return -1;
  if (v < 2925) return 0;
  if (v < 3510) return 1;
  return 2;
}

int8_t clampOctave(int8_t o) {
  if (o < -4) return -4;
  if (o > 2) return 2;
  return o;
}

int invertPotValue(int raw) {
  return 4095 - constrain(raw, 0, 4095);
}

float keyToFreqPentatonic(int col) {
  static const int8_t pentatonic[COLS] = {0, 3, 5, 7, 10, 12, 15, 17};
  const float rootHz = 110.0f;
  int idx = constrain(col, 0, COLS - 1);
  float hz = rootHz * powf(2.0f, (float)pentatonic[idx] / 12.0f);
  return applyOctave(hz, octaveShift);
}

float keyToFreqScale4x4(int row, int col) {
  int rr = constrain(row, 0, 3);
  int cc = constrain(col, 0, 3);
  int idx = rr * 4 + cc;
  float rootHz = 110.0f;
  int8_t semi = scaleMap[currentScaleIndex % 4][idx];
  float hz = rootHz * powf(2.0f, (float)semi / 12.0f);
  return applyOctave(hz, octaveShift);
}

float keyToFreqPentatonic4x4(int row, int col) {
  static const int8_t pent16[16] = {0,3,5,7, 10,12,15,17, 19,22,24,27, 29,31,34,36};
  int idx = constrain(row, 0, 3) * 4 + constrain(col, 0, 3);
  float rootHz = 110.0f;
  float hz = rootHz * powf(2.0f, (float)pent16[idx] / 12.0f);
  return applyOctave(hz, octaveShift);
}

void clearAllEffects() {
  for (int i = 0; i < EFFECT_COUNT; i++) effectEnabled[i] = false;
}

bool anyEffectEnabled() {
  for (int i = 0; i < EFFECT_COUNT; i++) {
    if (effectEnabled[i]) return true;
  }
  return false;
}

bool isEffectActive(int idx) {
  if (idx == 0) return false; // None
  // Classic behavior: selected effect always works with FXLv.
  // FX mode behavior: toggled effects can be layered and persist.
  return (idx == cachedEffectIndex) || effectEnabled[idx];
}

void toggleEffectSlot(int idx) {
  if (idx < 0 || idx >= EFFECT_COUNT) return;
  if (idx == 0) {
    cachedEffectIndex = 0;
    clearAllEffects();
    return;
  }
  effectEnabled[idx] = !effectEnabled[idx];
  cachedEffectIndex = idx;
}

void resetDrumTransport(bool keepRunning) {
  drumStep = 0;
  lastStepMs = millis();
  if (!keepRunning) drumRun = false;
}

void registerTapTempo() {
  unsigned long now = millis();
  if (lastTapMs != 0 && (now - lastTapMs) >= 180 && (now - lastTapMs) <= 1200) {
    tapTimes[tapCount & 0x03] = now - lastTapMs;
    if (tapCount < 4) tapCount++;
    unsigned long total = 0;
    for (uint8_t i = 0; i < tapCount; i++) total += tapTimes[i];
    if (total > 0) {
      float avg = (float)total / (float)tapCount;
      bpm = (uint16_t)constrain((int)lroundf(60000.0f / avg), 80, 120);
      resetDrumTransport(true);
    }
  } else {
    tapCount = 0;
  }
  lastTapMs = now;
}



void allNotesOff() {
  for (int i = 0; i < VOICE_COUNT; i++) {
    voices[i].active = false;
    voices[i].gate = false;
    envelope[i].noteOff();
  }
}

int getButtonLedIndex(int row, int col) {
  int ledsPerRow = COLS * LEDS_PER_BUTTON;
  int btnInRow   = (row % 2 == 0) ? col : (COLS - 1) - col;
  return (row * ledsPerRow) + (btnInRow * LEDS_PER_BUTTON);
}

void lightButton(int row, int col, uint32_t color) {
  int first = getButtonLedIndex(row, col);
  for (int i = 0; i < LEDS_PER_BUTTON; i++) strip.setPixelColor(first + i, color);
}

void lightExtraButton(int idx, uint32_t color) {
  int first = (MAIN_BUTTONS * LEDS_PER_BUTTON) + (idx * LEDS_PER_BUTTON);
  for (int i = 0; i < LEDS_PER_BUTTON; i++) strip.setPixelColor(first + i, color);
}

uint32_t scaleColor(uint32_t color, uint8_t s) {
  uint8_t r = (uint16_t)((color >> 16) & 0xFF) * s / 255;
  uint8_t g = (uint16_t)((color >>  8) & 0xFF) * s / 255;
  uint8_t b = (uint16_t)( color        & 0xFF) * s / 255;
  return strip.Color(r, g, b);
}

void audioOutput(const AudioOutput f) {
  // AudioOutput is an internal Mozzi frame type; convert explicitly to 16-bit PCM.
  int32_t mono = (int32_t)f.l();
#if MOZZI_AUDIO_BITS < 16
  mono <<= (16 - MOZZI_AUDIO_BITS);
#elif MOZZI_AUDIO_BITS > 16
  mono >>= (MOZZI_AUDIO_BITS - 16);
#endif
  if (mono > 32767) mono = 32767;
  if (mono < -32768) mono = -32768;
  int16_t sample16 = (int16_t)mono;
  int16_t stereo[2] = { sample16, sample16 };
  i2s.write((uint8_t*)stereo, sizeof(stereo));
}

int16_t compress16(int32_t sample, int16_t threshold, uint8_t ratioShift) {
  if (sample > threshold) {
    sample = threshold + ((sample - threshold) >> ratioShift);
  } else if (sample < -threshold) {
    sample = -threshold + ((sample + threshold) >> ratioShift);
  }
  return (int16_t)constrain(sample, -32767, 32767);
}

// ============================================================
//  VOIX — gestion polyphonie
// ============================================================
void applyEnvPreset(int i) {
  envelope[i].setADLevels(255, envPresets[cachedEnvIndex].sustainLevel);
  envelope[i].setTimes(
    envPresets[cachedEnvIndex].attackMs,
    envPresets[cachedEnvIndex].decayMs,
    600000,
    envPresets[cachedEnvIndex].releaseMs
  );
}

int8_t currentArpSemitone() {
  if (cachedArpIndex <= 0) return 0;
  if (cachedArpIndex == (ARP_PRESET_COUNT - 1)) {
    return userArpSteps[arpStep & 0x03];
  }
  uint8_t stepCount = arpPresets[cachedArpIndex].stepCount;
  if (stepCount == 0) return 0;
  return arpPresets[cachedArpIndex].steps[arpStep % stepCount];
}

void setVoicePlayFreq(int i, float playFreq) {
  voiceTargetFreq[i] = playFreq;
  if (cachedEnvIndex != ENV_MODE_SLIDE || !voices[i].active) {
    voiceCurFreq[i] = playFreq;
  }
  setVoiceFreq(i, voiceCurFreq[i]);
}

void setVoiceFreq(int i, float freq) {
  oscSin[i].setFreq(freq);
  oscSaw[i].setFreq(freq);
  oscSaw2[i].setFreq(freq * 1.022f);   // légèrement désaccordé
  oscSqr[i].setFreq(freq);
  oscTri[i].setFreq(freq);
  oscCheby[i].setFreq(freq * 0.5f);    // sous-octave pour richesse
}

void noteOn(uint8_t key, float baseFreq, float playFreq) {
  if (cachedEnvIndex == ENV_MODE_SLIDE) {
    for (int i = 0; i < VOICE_COUNT; i++) {
      if (voices[i].active) {
        voices[i].gate = true;
        voices[i].key = key;
        voices[i].baseFreq = baseFreq;
        voiceTargetFreq[i] = playFreq;
        applyEnvPreset(i);
        envelope[i].noteOn();
        return;
      }
    }
  }

  // Retrigger si déjà actif
  for (int i = 0; i < VOICE_COUNT; i++) {
    if (voices[i].active && voices[i].key == key) {
      voices[i].gate    = true;
      voices[i].baseFreq = baseFreq;
      setVoicePlayFreq(i, playFreq);
      voicePitchEnvSemi[i] = (cachedEnvIndex == ENV_MODE_PITCH) ? 7.0f : 0.0f;
      voiceHoldGain[i] = 1.0f;
      applyEnvPreset(i);
      envelope[i].noteOn();
      return;
    }
  }
  // Voix libre
  int idx = -1;
  for (int i = 0; i < VOICE_COUNT; i++) {
    if (!voices[i].active) { idx = i; break; }
  }
  if (idx < 0) idx = 0;  // vol stealing simplifié

  voices[idx] = {true, true, key, baseFreq};
  voiceCurFreq[idx] = playFreq;
  setVoicePlayFreq(idx, playFreq);
  voicePitchEnvSemi[idx] = (cachedEnvIndex == ENV_MODE_PITCH) ? 7.0f : 0.0f;
  voiceHoldGain[idx] = 1.0f;
  applyEnvPreset(idx);
  envelope[idx].noteOn();
}

void noteOff(uint8_t key) {
  for (int i = 0; i < VOICE_COUNT; i++) {
    if (voices[i].active && voices[i].key == key) {
      voices[i].gate = false;
      envelope[i].noteOff();
    }
  }
}

// ============================================================
//  DRUMS — déclenchement
// ============================================================
void triggerDrum(uint8_t row) {
  if (row >= DRUM_ROWS) return;
  static unsigned long lastTrigMs[DRUM_ROWS] = {0};
  unsigned long now = millis();
  if (now - lastTrigMs[row] < 12) return;
  lastTrigMs[row] = now;
  const DrumBank &bank = drumBanks[currentDrumBank];
  drumActive[row] = true;
  drumTrigMs[row] = now;
  float randNorm = ((float)random(-100, 101)) / 1000.0f;
  switch (row) {
    case 0: // Perc haut (safe) — plus doux que le kick
      kickFreqCurrent = bank.snareStartHz * (0.72f + randNorm * 0.18f);
      drumSinKick.setFreq(applyOctave(kickFreqCurrent, octaveShift));
      drumEnv[row].setADLevels(255, 0);
      drumEnv[row].setTimes(1, constrain(bank.snareDecay + random(-8, 10), 10, 85), 0, bank.snareDecay + 12);
      break;
    case 1: // Snare — sinus médium + bruit
      snareFreqCurrent = bank.snareStartHz * (1.0f + randNorm * 0.35f);
      drumSinSnare.setFreq(applyOctave(snareFreqCurrent, octaveShift));
      drumEnv[row].setADLevels(255, 0);
        drumEnv[row].setTimes(2, constrain(bank.snareDecay + random(-10, 11), 12, 120), 0, bank.snareDecay + 20);
      if (!drumSampleActive) {
        drumSample.start();
        drumSampleActive = true;
        drumSampleRole = 1; // snare
      }
      break;
    case 2: // HiHat fermé — bruit court
      hatFreqCurrent = bank.hhStartHz * (1.0f + randNorm * 0.60f);
      drumSinHat.setFreq(applyOctave(hatFreqCurrent, octaveShift));
      drumEnv[row].setADLevels(255, 0);
        drumEnv[row].setTimes(1, constrain(bank.hhDecay + random(-6, 7), 4, 70), 0, bank.hhDecay + 8);
      break;
    case 3: // Clap — bruit un peu plus long
      clapFreqCurrent = bank.clapStartHz * (1.0f + randNorm * 0.50f);
      drumSinClap.setFreq(applyOctave(clapFreqCurrent, octaveShift));
      drumEnv[row].setADLevels(255, 0);
        drumEnv[row].setTimes(2, constrain(bank.clapDecay + random(-8, 11), 10, 120), 0, bank.clapDecay + 18);
      if (!drumSampleActive) {
        drumSample.start();
        drumSampleActive = true;
        drumSampleRole = 3; // clap
      }
      break;
  }
  drumEnv[row].noteOn();
}

void triggerDrumVoice(uint8_t row, uint8_t variant) {
  if (row >= DRUM_ROWS) return;
  static unsigned long lastTrigMs[DRUM_ROWS] = {0};
  unsigned long now = millis();
  if (now - lastTrigMs[row] < 12) return;
  lastTrigMs[row] = now;
  const DrumBank &bank = drumBanks[currentDrumBank];
  drumActive[row] = true;
  drumTrigMs[row] = now;

  float v = (float)variant / (float)(COLS - 1);  // 0..1
  switch (row) {
    case 0: {
      float start = bank.snareStartHz * (0.60f + 0.45f * v);
      kickFreqCurrent = start;
      drumSinKick.setFreq(applyOctave(kickFreqCurrent, octaveShift));
      uint8_t d = (uint8_t)constrain((int)bank.snareDecay + (int)(v * 24.0f) - 10, 10, 85);
      drumEnv[row].setADLevels(255, 0);
      drumEnv[row].setTimes(1, d, 0, d + 10);
      break;
    }
    case 1: {
      float start = bank.snareStartHz * (0.85f + 0.45f * v);
      snareFreqCurrent = start;
      drumSinSnare.setFreq(applyOctave(snareFreqCurrent, octaveShift));
      uint8_t d = (uint8_t)constrain((int)bank.snareDecay + (int)(v * 36.0f) - 14, 14, 120);
      drumEnv[row].setADLevels(255, 0);
      drumEnv[row].setTimes(1, d, 0, d + 24);
      if (!drumSampleActive) {
        drumSample.start();
        drumSampleActive = true;
        drumSampleRole = 1; // snare
      }
      break;
    }
    case 2: {
      float start = bank.hhStartHz * (0.9f + 0.9f * v);
      hatFreqCurrent = start;
      drumSinHat.setFreq(applyOctave(hatFreqCurrent, octaveShift));
      uint8_t d = (uint8_t)constrain((int)bank.hhDecay + (int)(v * 24.0f), 6, 70);
      drumEnv[row].setADLevels(255, 0);
      drumEnv[row].setTimes(1, d, 0, d + 10);
      break;
    }
    case 3: {
      float start = bank.clapStartHz * (0.9f + 0.7f * v);
      clapFreqCurrent = start;
      drumSinClap.setFreq(applyOctave(clapFreqCurrent, octaveShift));
      uint8_t d = (uint8_t)constrain((int)bank.clapDecay + (int)(v * 30.0f) - 10, 10, 100);
      drumEnv[row].setADLevels(255, 0);
      drumEnv[row].setTimes(1, d, 0, d + 18);
      if (!drumSampleActive) {
        drumSample.start();
        drumSampleActive = true;
        drumSampleRole = 3; // clap
      }
      break;
    }
  }
  drumEnv[row].noteOn();
}

// ============================================================
//  SCAN BOUTONS
// ============================================================
void scanButtons() {
  uint16_t b1 = mcp1.readGPIOAB();
  uint16_t b2 = mcp2.readGPIOAB();
  uint32_t nextMainMask = 0;
  for (int i = 0; i < MAIN_BUTTONS; i++) {
    bool raw = (i < 16) ? !(b1 & (1 << i)) : !(b2 & (1 << (i - 16)));
    int row = i / COLS;
    int col = (COLS - 1) - (i % COLS);
    int key = row * COLS + col;
    if (raw) nextMainMask |= (1UL << key);
  }
  uint16_t bx = mcpExtra.readGPIOAB();
  uint8_t nextExtraMask = 0;
  for (int i = 0; i < EXTRA_BUTTONS; i++) {
    bool raw = !(bx & (1 << extraMcpPins[i]));
    if (raw) nextExtraMask |= (1U << i);
  }

  portENTER_CRITICAL(&buttonMaskMux);
  bool changed = (nextMainMask != scannedMainMask) || (nextExtraMask != scannedExtraMask);
  scannedMainMask = nextMainMask;
  scannedExtraMask = nextExtraMask;
  if (changed) scannedButtonsDirty = true;
  portEXIT_CRITICAL(&buttonMaskMux);
}

void consumeButtonEvents() {
  uint32_t latestMainMask;
  uint8_t latestExtraMask;
  bool hadChanges;

  portENTER_CRITICAL(&buttonMaskMux);
  latestMainMask = scannedMainMask;
  latestExtraMask = scannedExtraMask;
  hadChanges = scannedButtonsDirty;
  scannedButtonsDirty = false;
  portEXIT_CRITICAL(&buttonMaskMux);

  uint32_t changedMainMask = latestMainMask ^ consumedMainMask;
  uint8_t changedExtraMask = latestExtraMask ^ consumedExtraMask;

  for (int i = 0; i < TOTAL_BUTTONS; i++) {
    prevPressed[i] = pressed[i];
    justPressed[i] = false;
    justReleased[i] = false;
  }

  for (int key = 0; key < MAIN_BUTTONS; key++) {
    bool isPressed = ((latestMainMask >> key) & 0x1U) != 0;
    bool changed = ((changedMainMask >> key) & 0x1U) != 0;
    pressed[key] = isPressed;
    justPressed[key] = changed && isPressed;
    justReleased[key] = changed && !isPressed;
  }

  for (int i = 0; i < EXTRA_BUTTONS; i++) {
    int key = MAIN_BUTTONS + i;
    bool isPressed = ((latestExtraMask >> i) & 0x1U) != 0;
    bool changed = ((changedExtraMask >> i) & 0x1U) != 0;
    pressed[key] = isPressed;
    justPressed[key] = changed && isPressed;
    justReleased[key] = changed && !isPressed;
  }

  consumedMainMask = latestMainMask;
  consumedExtraMask = latestExtraMask;
  if (hadChanges || changedMainMask != 0 || changedExtraMask != 0) ledRefreshRequested = true;
}

void buttonScanTask(void* parameter) {
  (void)parameter;
  for (;;) {
    scanButtons();
    vTaskDelay(BUTTON_SCAN_TASK_DELAY_TICKS);
  }
}

void uiTask(void* parameter) {
  (void)parameter;
  for (;;) {
    unsigned long now = millis();

    if (now - lastPotReadMs >= 8) {
      lastPotReadMs = now;
      readPots();
    }

    if (ledRefreshRequested && (lastLedMs == 0 || (now - lastLedMs >= 8))) {
      lastLedMs = now;
      ledRefreshRequested = false;
      renderLeds();
    }

    if (displayRefreshRequested && (now - lastDisplayMs >= 120)) {
      lastDisplayMs = now;
      displayRefreshRequested = false;
      renderDisplay();
    }

    vTaskDelay(UI_TASK_DELAY_TICKS);
  }
}

// ============================================================
//  LECTURE POTS (filtre adaptatif, comme mini_instru)
// ============================================================
void readPots() {
  static uint32_t lastPotDebugMs = 0;

  for (int i = 0; i < 5; i++) {
    int raw = analogRead(POT_PINS[i]);
    potRaw[i] = raw;
    float inverted = (float)invertPotValue(raw);
    potSmooth[i] += POT_ALPHA * (inverted - potSmooth[i]);
    potFilt[i] = (int)potSmooth[i];
  }

  float targetVol = map(potFilt[0], 0, 4095, 0, 160000);
  masterVolume   += 0.03f * (targetVol - masterVolume);

  // Shape et effet sont gérés par boutons ergonomiques en mode instrument/autres.
  fxAmount       = (uint8_t)constrain(map(potFilt[1], 0, 4095, 0, 255), 0, 255);
  cachedEnvIndex = constrain(map(potFilt[2], 0, 4095, 0, ENV_PRESET_COUNT - 1), 0, ENV_PRESET_COUNT - 1);
  bpm            = (uint16_t)constrain(map(potFilt[3], 0, 4095, 80, 120), 80, 120);

  // Quantification d'octave simple + hysteresis legere anti-jitter.
  int8_t nextOct = quantizeOctaveFromPot(potFilt[4]);
  if (nextOct != octaveStable) {
    int center = ((int)(nextOct + 4) * 4095) / 6;
    int dist = abs(potFilt[4] - center);
    if (dist > 120) octaveStable = nextOct;
  }
  octaveShift = octaveStable;

  // En drumbox et drum-instrument, POT_PARAM_1 devient sélecteur de bank.
  if (currentMode == MODE_DRUMBOX || currentMode == MODE_DRUM_INSTRUMENT) {
    currentDrumBank = constrain(map(potFilt[1], 0, 4095, 0, (int)DRUM_BANK_COUNT - 1), 0, (int)DRUM_BANK_COUNT - 1);
  }

  uint32_t now = millis();
#if ENABLE_POT_DEBUG
  if (now - lastPotDebugMs >= 350) {
    lastPotDebugMs = now;
    Serial.println("[POT DEBUG] idx pin raw filt");
    for (int i = 0; i < 5; i++) {
      Serial.print("[POT DEBUG] ");
      Serial.print(i);
      Serial.print(" ");
      Serial.print(potNames[i]);
      Serial.print(" GPIO");
      Serial.print(POT_PINS[i]);
      Serial.print(" raw=");
      Serial.print(potRaw[i]);
      Serial.print(" filt=");
      Serial.print(potFilt[i]);
      Serial.println();
    }
    Serial.print("[POT DEBUG] octave=");
    Serial.println(octaveShift);
  }
#else
  (void)now;
  (void)lastPotDebugMs;
#endif
}

// ============================================================
//  EXTRA BOUTONS
// ============================================================
void handleExtraButtons() {
  // Combo: instrument + effet -> Scale Help toggle
  bool comboScale = pressed[MAIN_BUTTONS + EXTRA_MODE_INSTRUMENT] && pressed[MAIN_BUTTONS + EXTRA_DRUM_CLEAR];
  if (comboScale) {
    if (currentMode != MODE_SCALE_HELP) {
      currentMode = MODE_SCALE_HELP;
      allNotesOff();
    } else {
      currentMode = MODE_INSTRUMENT;
      allNotesOff();
    }
  }

  if (justPressed[MAIN_BUTTONS + EXTRA_MODE_INSTRUMENT]) {
    currentMode = (AppMode)(((int)currentMode + 1) % APP_MODE_COUNT);
    if (currentMode == MODE_SCALE_HELP) currentMode = MODE_INSTRUMENT;
  }

  if (currentMode == MODE_DRUMBOX) {
    if (justPressed[MAIN_BUTTONS + EXTRA_MODE_DRUMBOX]) {
      drumRun = !drumRun;
      if (drumRun) lastStepMs = millis();
    }
    if (justPressed[MAIN_BUTTONS + EXTRA_DRUM_PLAY]) {
      resetDrumTransport(true);
    }
    if (justPressed[MAIN_BUTTONS + EXTRA_DRUM_CLEAR]) {
      registerTapTempo();
    }
    return;
  }

  // Long press reset behavior (500ms)
  unsigned long now = millis();
  if (pressed[MAIN_BUTTONS + EXTRA_MODE_DRUMBOX]) {
    if (holdStartShapeMs == 0) holdStartShapeMs = now;
    if (!holdDoneShape && now - holdStartShapeMs >= HOLD_RESET_MS) {
      cachedShape = 0;
      holdDoneShape = true;
    }
  } else {
    holdStartShapeMs = 0;
    holdDoneShape = false;
  }

  if (pressed[MAIN_BUTTONS + EXTRA_DRUM_PLAY]) {
    if (holdStartArpMs == 0) holdStartArpMs = now;
    if (!holdDoneArp && now - holdStartArpMs >= HOLD_RESET_MS) {
      cachedArpIndex = 0;
      arpStep = 0;
      holdDoneArp = true;
    }
  } else {
    holdStartArpMs = 0;
    holdDoneArp = false;
  }

  if (pressed[MAIN_BUTTONS + EXTRA_DRUM_CLEAR]) {
    if (holdStartFxMs == 0) holdStartFxMs = now;
    if (!holdDoneFx && now - holdStartFxMs >= HOLD_RESET_MS) {
      cachedEffectIndex = 0;
      clearAllEffects();
      holdDoneFx = true;
    }
  } else {
    holdStartFxMs = 0;
    holdDoneFx = false;
  }

  if (currentMode == MODE_FX) {
    if (justPressed[MAIN_BUTTONS + EXTRA_MODE_DRUMBOX]) cachedShape = (cachedShape + 1) % SHAPE_COUNT;
    if (justPressed[MAIN_BUTTONS + EXTRA_DRUM_PLAY]) clearAllEffects();
    if (justPressed[MAIN_BUTTONS + EXTRA_DRUM_CLEAR]) cachedEffectIndex = (cachedEffectIndex + 1) % EFFECT_COUNT;
    return;
  }

  if (justPressed[MAIN_BUTTONS + EXTRA_MODE_DRUMBOX]) {
    cachedShape = (cachedShape + 1) % SHAPE_COUNT;
  }
  if (justPressed[MAIN_BUTTONS + EXTRA_DRUM_PLAY]) {
    cachedArpIndex = (cachedArpIndex + 1) % ARP_PRESET_COUNT;
    arpStep = 0;
    userArpWritePos = 0;
  }
  if (justPressed[MAIN_BUTTONS + EXTRA_DRUM_CLEAR]) {
    cachedEffectIndex = (cachedEffectIndex + 1) % EFFECT_COUNT;
  }
}

void handleDrumInstrumentMode() {
  for (int key = 0; key < MAIN_BUTTONS; key++) {
    if (!justPressed[key]) continue;
    int row = key / COLS;
    int col = key % COLS;
    // Clavier split: 4 colonnes gauche = setup loop, 4 colonnes droite = jeu drum
    if (col < 4) {
      int stepA = col * 2;
      int stepB = stepA + 1;
      bool next = !drumPattern[row][stepA];
      drumPattern[row][stepA] = next;
      drumPattern[row][stepB] = next;
      continue;
    }
    triggerDrumVoice((uint8_t)row, (uint8_t)(col - 4));
  }
}

void handleFxMode() {
  for (int key = 0; key < MAIN_BUTTONS; key++) {
    int row = key / COLS;
    int col = key % COLS;
    if (col < 4) {
      if (justPressed[key]) {
        float hz = keyToFreqPentatonic4x4(row, col);
        noteOn((uint8_t)key, hz, hz);
      }
      if (justReleased[key]) {
        noteOff((uint8_t)key);
      }
      continue;
    }

    if (!justPressed[key]) {
      continue;
    }

    int slot = row * 4 + (col - 4); // 16 slots on right half
    if (slot < EFFECT_COUNT) {
      toggleEffectSlot(slot);
    } else if (slot == EFFECT_COUNT) {
      clearAllEffects();
    } else if (slot == EFFECT_COUNT + 1) {
      fxAmount = 64;
    } else if (slot == EFFECT_COUNT + 2) {
      fxAmount = 200;
    }
  }
}

void handleScaleHelpMode() {
  for (int key = 0; key < MAIN_BUTTONS; key++) {
    int row = key / COLS;
    int col = key % COLS;
    if (justPressed[key]) {
      float hz = keyToFreqScale4x4(row, col < 4 ? col : col - 4);
      noteOn((uint8_t)key, hz, hz);
    }
    if (justReleased[key]) {
      noteOff((uint8_t)key);
    }
  }

  // In scale helper, extra buttons navigate scale/musical variation.
  if (justPressed[MAIN_BUTTONS + EXTRA_MODE_DRUMBOX]) {
    currentScaleIndex = (currentScaleIndex + 1) % 4;
  }
  if (justPressed[MAIN_BUTTONS + EXTRA_DRUM_PLAY]) {
    cachedArpIndex = (cachedArpIndex + 1) % ARP_PRESET_COUNT;
    arpStep = 0;
  }
  if (justPressed[MAIN_BUTTONS + EXTRA_DRUM_CLEAR]) {
    cachedShape = (cachedShape + 1) % SHAPE_COUNT;
  }
}

void handleDrumShowMode() {
  for (int key = 0; key < MAIN_BUTTONS; key++) {
    if (!justPressed[key]) continue;
    int row = key / COLS;
    int col = key % COLS;
    if (row == 0 && col < 4) {
      drumShowLoopEnabled[col] = !drumShowLoopEnabled[col];
      continue;
    }
    if (row == 0 && col >= 4) {
      drumShowDivisionIndex = col - 4;
      resetDrumTransport(true);
      continue;
    }
    triggerDrumVoice((uint8_t)row, (uint8_t)col);
  }
}

void handleLightShowMode() {
  for (int key = 0; key < MAIN_BUTTONS; key++) {
    if (justPressed[key]) lightPulse[key] = 255;
  }
}

bool tetrisCellOccupiedByPiece(int r, int c) {
  if (r == tetrisY && c == tetrisX) return true;
  if (tetrisHorizontal) {
    if (r == tetrisY && c == tetrisX + 1) return true;
  } else {
    if (r == tetrisY + 1 && c == tetrisX) return true;
  }
  return false;
}

bool tetrisCanPlace(int x, int y, bool horizontal) {
  if (x < 0 || y < 0) return false;
  if (horizontal) {
    if (x + 1 >= COLS || y >= ROWS) return false;
    if (tetrisGrid[y][x] || tetrisGrid[y][x + 1]) return false;
  } else {
    if (x >= COLS || y + 1 >= ROWS) return false;
    if (tetrisGrid[y][x] || tetrisGrid[y + 1][x]) return false;
  }
  return true;
}

void tetrisLockPiece() {
  if (tetrisY >= 0 && tetrisY < ROWS && tetrisX >= 0 && tetrisX < COLS) tetrisGrid[tetrisY][tetrisX] = true;
  if (tetrisHorizontal) {
    if (tetrisY >= 0 && tetrisY < ROWS && tetrisX + 1 >= 0 && tetrisX + 1 < COLS) tetrisGrid[tetrisY][tetrisX + 1] = true;
  } else {
    if (tetrisY + 1 >= 0 && tetrisY + 1 < ROWS && tetrisX >= 0 && tetrisX < COLS) tetrisGrid[tetrisY + 1][tetrisX] = true;
  }
}

void tetrisClearLines() {
  for (int r = ROWS - 1; r >= 0; r--) {
    bool full = true;
    for (int c = 0; c < COLS; c++) {
      if (!tetrisGrid[r][c]) { full = false; break; }
    }
    if (full) {
      for (int rr = r; rr > 0; rr--) {
        for (int c = 0; c < COLS; c++) tetrisGrid[rr][c] = tetrisGrid[rr - 1][c];
      }
      for (int c = 0; c < COLS; c++) tetrisGrid[0][c] = false;
      r++;
    }
  }
}

void tetrisSpawnPiece() {
  tetrisHorizontal = ((millis() >> 3) & 1) == 0;
  tetrisX = tetrisHorizontal ? 3 : 4;
  tetrisY = 0;
  if (!tetrisCanPlace(tetrisX, tetrisY, tetrisHorizontal)) tetrisGameOver = true;
}

void handleTetrisMode() {
  if (tetrisGameOver) {
    if (justPressed[MAIN_BUTTONS + EXTRA_DRUM_CLEAR]) {
      memset(tetrisGrid, 0, sizeof(tetrisGrid));
      tetrisGameOver = false;
      tetrisSpawnPiece();
    }
    return;
  }

  for (int key = 0; key < MAIN_BUTTONS; key++) {
    if (!justPressed[key]) continue;
    int row = key / COLS;
    int col = key % COLS;
    if (row == 3 && col <= 3) {
      if (col == 0 && tetrisCanPlace(tetrisX - 1, tetrisY, tetrisHorizontal)) tetrisX--;
      if (col == 1 && tetrisCanPlace(tetrisX + 1, tetrisY, tetrisHorizontal)) tetrisX++;
      if (col == 2) {
        bool next = !tetrisHorizontal;
        if (tetrisCanPlace(tetrisX, tetrisY, next)) tetrisHorizontal = next;
      }
      if (col == 3) {
        while (tetrisCanPlace(tetrisX, tetrisY + 1, tetrisHorizontal)) tetrisY++;
      }
    }
  }

  unsigned long fallMs = (unsigned long)constrain(700 - (int)bpm * 2, 120, 700);
  if (millis() - tetrisLastFallMs >= fallMs) {
    tetrisLastFallMs = millis();
    if (tetrisCanPlace(tetrisX, tetrisY + 1, tetrisHorizontal)) {
      tetrisY++;
    } else {
      tetrisLockPiece();
      tetrisClearLines();
      tetrisSpawnPiece();
    }
  }
}

uint8_t glyphCol(char c, uint8_t col) {
  switch (c) {
    case 'M': { const uint8_t g[4] = {0x0F, 0x06, 0x0F, 0x09}; return (col < 4) ? g[col] : 0; }
    case 'O': { const uint8_t g[3] = {0x06, 0x09, 0x06}; return (col < 3) ? g[col] : 0; }
    case 'Z': { const uint8_t g[3] = {0x0F, 0x05, 0x0F}; return (col < 3) ? g[col] : 0; }
    case 'I': { const uint8_t g[1] = {0x0F}; return (col < 1) ? g[col] : 0; }
    case 'V': { const uint8_t g[3] = {0x0E, 0x01, 0x0E}; return (col < 3) ? g[col] : 0; }
    case '2': { const uint8_t g[3] = {0x0D, 0x0B, 0x09}; return (col < 3) ? g[col] : 0; }
    default: return 0;
  }
}

uint8_t glyphWidth(char c) {
  switch (c) {
    case 'M': return 4;
    case 'I': return 1;
    case ' ': return 2;
    default: return 3;
  }
}

uint8_t scrollBitAtColumn(int col) {
  int idx = 0;
  int msgLen = strlen(scrollText);
  for (int i = 0; i < msgLen; i++) {
    char ch = scrollText[i];
    uint8_t w = glyphWidth(ch);
    if (col < idx + w) return glyphCol(ch, col - idx);
    idx += w + 1;
  }
  return 0;
}

int scrollPatternLength() {
  int total = 0;
  int msgLen = strlen(scrollText);
  for (int i = 0; i < msgLen; i++) total += glyphWidth(scrollText[i]) + 1;
  return total;
}

void handleTextMode() {
  unsigned long stepMs = (unsigned long)constrain(220 - (int)(bpm / 2), 40, 220);
  if (millis() - scrollLastMs >= stepMs) {
    scrollLastMs = millis();
    int plen = scrollPatternLength();
    scrollColumn = (scrollColumn + 1) % plen;
  }
}

// ============================================================
//  MODE INSTRUMENT
// ============================================================
void handleInstrumentMode() {
  // Apprentissage des notes d'arpège custom: maintenir bouton ARP et appuyer des touches.
  if (cachedArpIndex == (ARP_PRESET_COUNT - 1) && pressed[MAIN_BUTTONS + EXTRA_DRUM_PLAY]) {
    for (int key = 0; key < MAIN_BUTTONS; key++) {
      if (!justPressed[key]) continue;
      int row = key / COLS;
      int col = key % COLS;
      int semi = col * 4 + row;
      userArpSteps[userArpWritePos & 0x03] = (int8_t)semi;
      userArpWritePos++;
    }
  }

  // Arpégiateur : avance régulièrement et applique offset sur voix actives
  if (cachedArpIndex > 0) {
    unsigned long period = (unsigned long)(1000.0f / arpRateHz);
    if (millis() - arpLastMs >= period) {
      arpLastMs = millis();
      uint8_t stepCount = (cachedArpIndex == (ARP_PRESET_COUNT - 1)) ? 4 : arpPresets[cachedArpIndex].stepCount;
      arpStep   = (arpStep + 1) % stepCount;
      for (int i = 0; i < VOICE_COUNT; i++) {
        if (voices[i].active && voices[i].gate) {
          float f = voices[i].baseFreq * powf(2.0f, (float)currentArpSemitone() / 12.0f);
          setVoicePlayFreq(i, f);
        }
      }
    }
  }

  for (int key = 0; key < MAIN_BUTTONS; key++) {
    if (justPressed[key]) {
      float baseFreq = keyToFreqColumnOrder(key);
      float playFreq = baseFreq;
      if (cachedArpIndex > 0) {
        playFreq *= powf(2.0f, (float)currentArpSemitone() / 12.0f);
      }
      noteOn(key, baseFreq, playFreq);
    }
    if (justReleased[key]) noteOff(key);
  }
}

// ============================================================
//  MODE DRUM
// ============================================================
void handleDrumMode() {
  for (int key = 0; key < MAIN_BUTTONS; key++) {
    if (!justPressed[key]) continue;
    int row = key / COLS;
    int col = key % COLS;
    drumPattern[row][col] = !drumPattern[row][col];
  }
}

void processInputActions() {
  handleExtraButtons();

  if (currentMode == MODE_INSTRUMENT) handleInstrumentMode();
  else if (currentMode == MODE_DRUMBOX) handleDrumMode();
  else if (currentMode == MODE_DRUM_INSTRUMENT) handleDrumInstrumentMode();
  else if (currentMode == MODE_SCALE_HELP) handleScaleHelpMode();
  else handleFxMode();

  if (currentMode != previousMode) {
    if (previousMode == MODE_INSTRUMENT || previousMode == MODE_FX) {
      allNotesOff();
    }
    previousMode = currentMode;
    ledRefreshRequested = true;
    displayRefreshRequested = true;
  }
}

void runDrumSequencer() {
  uint16_t stepMs = (uint16_t)constrain((60000UL / bpm) / 4, 20, 2000);
  unsigned long now = millis();
  if (drumRun && (now - lastStepMs >= stepMs)) {
    lastStepMs = now;
    drumStep   = (drumStep + 1) % COLS;
    for (int r = 0; r < DRUM_ROWS; r++) {
      if (drumPattern[r][drumStep]) triggerDrum((uint8_t)r);
    }
    ledRefreshRequested = true;
  }
}

// ============================================================
//  LEDs
// ============================================================
void renderLeds() {
  strip.clear();
  uint16_t t = (uint16_t)((millis() * (2 + bpm / 30)) & 0xFFFF);
  int pressedCount = countPressedMainButtons();
  uint8_t pressBoost = (uint8_t)constrain(80 + pressedCount * 10, 80, 220);

  if (currentMode == MODE_INSTRUMENT) {
    for (int r = 0; r < ROWS; r++) {
      for (int c = 0; c < COLS; c++) {
        int k = r * COLS + c;
        uint16_t hue = (uint16_t)(t + c * 6000 + cachedShape * 2400 + cachedEffectIndex * 900);
        uint8_t val = pressed[k] ? (uint8_t)constrain(pressBoost + fxAmount / 4, 0, 255) : 8;
        lightButton(r, c, dynamicColor(hue, 230, val));
      }
    }
  } else if (currentMode == MODE_DRUMBOX) {
    for (int r = 0; r < DRUM_ROWS; r++) {
      for (int c = 0; c < COLS; c++) {
        uint16_t baseHue = (uint16_t)(drumBanks[currentDrumBank].hueBase + r * 8000 + c * 500 + t / 4);
        uint32_t base = drumPattern[r][c] ? dynamicColor(baseHue, 255, 140) : dynamicColor(baseHue, 120, 4);
        if (c == drumStep) base = dynamicColor(baseHue + 2000, 180, drumRun ? 255 : 90);
        lightButton(r, c, base);
      }
    }
  } else if (currentMode == MODE_DRUM_INSTRUMENT) {
    for (int r = 0; r < ROWS; r++) {
      for (int c = 0; c < COLS; c++) {
        int k = r * COLS + c;
        if (c < 4) {
          int stepA = c * 2;
          bool on = drumPattern[r][stepA];
          lightButton(r, c, dynamicColor((uint16_t)(8000 + r * 9000 + c * 2000 + t / 3), 220, on ? 200 : 20));
        } else {
          uint16_t hueBase = (uint16_t)(drumBanks[currentDrumBank].hueBase + r * 9000 + c * 1200 + t / 2);
          uint8_t val = pressed[k] ? 230 : 16;
          lightButton(r, c, dynamicColor(hueBase, 255, val));
        }
      }
    }
  } else if (currentMode == MODE_SCALE_HELP) {
    for (int r = 0; r < ROWS; r++) {
      for (int c = 0; c < COLS; c++) {
        int k = r * COLS + c;
        uint16_t base = (uint16_t)(currentScaleIndex * 14000 + c * 3000 + r * 9000 + t / 3);
        uint8_t val = pressed[k] ? 255 : 42;
        lightButton(r, c, dynamicColor(base, 230, val));
      }
    }
  } else {
    for (int r = 0; r < ROWS; r++) {
      for (int c = 0; c < COLS; c++) {
        int k = r * COLS + c;
        uint16_t hueBase = (uint16_t)(t + r * 9000 + c * 1500);
        if (c < 4) {
          uint8_t val = pressed[k] ? 255 : 28;
          lightButton(r, c, dynamicColor(hueBase, 180, val));
        } else {
          int slot = r * 4 + (c - 4);
          bool on = (slot < EFFECT_COUNT) ? effectEnabled[slot] : false;
          lightButton(r, c, dynamicColor(hueBase, on ? 255 : 120, on ? 220 : 12));
        }
      }
    }
  }
  lightExtraButton(EXTRA_MODE_INSTRUMENT, dynamicColor(t + 2000, 255, 140));
  lightExtraButton(EXTRA_MODE_DRUMBOX, dynamicColor(t + 14000, 255, (currentMode == MODE_DRUMBOX) ? (drumRun ? 255 : 120) : 140));
  lightExtraButton(EXTRA_DRUM_PLAY, dynamicColor(t + 30000, 255, 140));
  lightExtraButton(EXTRA_DRUM_CLEAR, dynamicColor(t + 46000, 255, 140));
  strip.show();
}

// ============================================================
//  AFFICHAGE OLED SH1107 128x128
// ============================================================
void renderDisplay() {
  u8g2.clearBuffer();
  u8g2.setFont(u8g2_font_6x12_tf);
  u8g2.drawFrame(sx(0), 0, 128, 128);
  u8g2.drawFrame(sx(2), 2, 124, 124);

  const char* modeLabel = modeName(currentMode);
  int tw = u8g2.getStrWidth(modeLabel);
  u8g2.setCursor(sx(64 - tw / 2), 15);
  u8g2.print(modeLabel);

  // Ligne séparatrice
  u8g2.drawHLine(sx(6), 19, 116);

  u8g2.setCursor(sx(6), 32); u8g2.print("Inst: "); u8g2.print(shapeNames[cachedShape]);
  u8g2.setCursor(sx(6), 45); u8g2.print("Env:  "); u8g2.print(envPresets[cachedEnvIndex].name);
  u8g2.setCursor(sx(6), 58); u8g2.print("FX:   "); u8g2.print(effectNames[cachedEffectIndex]); if (effectEnabled[cachedEffectIndex]) u8g2.print("*");
  u8g2.setCursor(sx(6), 71); u8g2.print("FXLv: "); u8g2.print((int)fxAmount);
  u8g2.setCursor(sx(6), 84); u8g2.print("Oct:  "); u8g2.print(octaveShift);
  u8g2.setCursor(sx(6), 97); u8g2.print("BPM:  "); u8g2.print((int)lroundf((float)bpm));

  if (currentMode == MODE_DRUMBOX) {
    u8g2.setCursor(sx(6), 110);
    u8g2.print("Step: ");
    u8g2.print(drumStep + 1);
    u8g2.print(drumRun ? " RUN" : " STOP");
    u8g2.setCursor(sx(6), 123);
    u8g2.print("Bank: ");
    u8g2.print(drumBanks[currentDrumBank].name);
  } else if (currentMode == MODE_SCALE_HELP) {
    u8g2.setCursor(sx(6), 110);
    u8g2.print("Scale: ");
    u8g2.print(scaleNames[currentScaleIndex % 4]);
    u8g2.setCursor(sx(6), 123);
    u8g2.print("Combo Inst+Fx quit");
  } else if (currentMode == MODE_INSTRUMENT) {
    u8g2.setCursor(sx(6), 110);
    u8g2.print("Arp:  ");
    if (cachedArpIndex == (ARP_PRESET_COUNT - 1)) u8g2.print("User");
    else u8g2.print(arpPresets[cachedArpIndex].name);
    u8g2.setCursor(sx(6), 123);
    u8g2.print("Vol:  ");
    u8g2.print((int)(masterVolume / 1600));
    u8g2.print("%");
  } else if (currentMode == MODE_FX) {
    u8g2.setCursor(sx(6), 110);
    u8g2.print("L4x4 notes R4x4 FX");
    u8g2.setCursor(sx(6), 123);
    u8g2.print(anyEffectEnabled() ? "FX stored" : "FX dry");
  } else {
    u8g2.setCursor(sx(6), 110);
    u8g2.print("L:loop R:drum");
    u8g2.setCursor(sx(6), 123);
    u8g2.print("Bank: ");
    u8g2.print(drumBanks[currentDrumBank].name);
  }

  u8g2.sendBuffer();
}

// ============================================================
//  MOZZI — updateControl()  (128 Hz)
// ============================================================
void updateControl() {
  // Retune immediat des notes tenues quand l'octave change.
  if (octaveShift != lastOctaveShift) {
    for (int i = 0; i < VOICE_COUNT; i++) {
      if (voices[i].active) {
        float base = keyToFreqColumnOrder(voices[i].key);
        voices[i].baseFreq = base;
        if (cachedArpIndex > 0 && voices[i].gate) {
          base *= powf(2.0f, (float)arpPresets[cachedArpIndex].steps[arpStep] / 12.0f);
        }
        setVoiceFreq(i, base);
      }
    }
    lastOctaveShift = octaveShift;
  }

  // La drumbox continue en fond, meme en mode instrument.
  runDrumSequencer();

  // Mise à jour enveloppes synth (doit être ici, pas dans updateAudio)
  for (int i = 0; i < VOICE_COUNT; i++) envelope[i].update();

  // Mise à jour enveloppes drums + sweep fréquence
  for (int r = 0; r < DRUM_ROWS; r++) {
    drumEnv[r].update();
    if (drumActive[r]) {
      unsigned long elapsed = millis() - drumTrigMs[r];
      const DrumBank &bank = drumBanks[currentDrumBank];
      if (r == 0) {
        // Kick : sweep exponentiel selon la bank
        float decay = expf(-(float)elapsed / bank.kickTauMs);
        kickFreqCurrent = bank.kickEndHz + (bank.kickStartHz - bank.kickEndHz) * decay;
        drumSinKick.setFreq(applyOctave(kickFreqCurrent, octaveShift));
      }
      if (r == 1) {
        // Snare : sweep selon la bank
        float decay = expf(-(float)elapsed / bank.snareTauMs);
        snareFreqCurrent = bank.snareEndHz + (bank.snareStartHz - bank.snareEndHz) * decay;
        drumSinSnare.setFreq(applyOctave(snareFreqCurrent, octaveShift));
      }
      if (r == 2) {
        float decay = expf(-(float)elapsed / bank.hhTauMs);
        hatFreqCurrent = bank.hhEndHz + (bank.hhStartHz - bank.hhEndHz) * decay;
        drumSinHat.setFreq(applyOctave(hatFreqCurrent, octaveShift));
      }
      if (r == 3) {
        float decay = expf(-(float)elapsed / bank.clapTauMs);
        clapFreqCurrent = bank.clapEndHz + (bank.clapStartHz - bank.clapEndHz) * decay;
        drumSinClap.setFreq(applyOctave(clapFreqCurrent, octaveShift));
      }
    }
  }
  drumMixAmount = drumBanks[currentDrumBank].mixLevel;

  // Arpégiateur : taux contrôlé par BPM
  arpRateHz = (float)bpm / 60.0f * 2.0f;

  // LEDs: on demande simplement un rafraichissement periodique ou sur evenement.
  if (++uiTick >= UI_TICKS_LEDS) {
    uiTick = 0;
    ledRefreshRequested = true;
  }

  // Display (toutes les UI_TICKS_DISP ticks)
  if (++dispTick >= UI_TICKS_DISP) {
    dispTick = 0;
    displayRefreshRequested = true;
  }
}

// ============================================================
//  MOZZI — updateAudio()  (~16384 Hz)
// ============================================================
#if (MOZZI_COMPATIBILITY_LEVEL <= MOZZI_COMPATIBILITY_1_1) && MOZZI_IS(MOZZI_AUDIO_CHANNELS, MOZZI_MONO)
AudioOutput_t updateAudio() {
#else
AudioOutput updateAudio() {
#endif
  int32_t mixedSynth = 0;
  int32_t mixedDrum = 0;
  int synthActive = 0;
  int drumCount = 0;

  // ── Voix synth ──
  for (int i = 0; i < VOICE_COUNT; i++) {
    if (!voices[i].active) continue;

    uint8_t env = envelope[i].next();

    // Déactiver quand enveloppe éteinte + gate relâché
    if (env == 0 && !voices[i].gate) {
      voices[i].active = false;
      continue;
    }

    if (cachedEnvIndex == ENV_MODE_FADE && voices[i].gate) {
      voiceHoldGain[i] *= 0.9996f;
      if (voiceHoldGain[i] < 0.12f) voiceHoldGain[i] = 0.12f;
    } else if (!voices[i].gate) {
      voiceHoldGain[i] *= 0.9985f;
    }

    if (cachedEnvIndex == ENV_MODE_PITCH && voicePitchEnvSemi[i] > 0.02f) {
      voicePitchEnvSemi[i] *= 0.9965f;
      float f = voiceTargetFreq[i] * powf(2.0f, voicePitchEnvSemi[i] / 12.0f);
      setVoiceFreq(i, f);
    }

    if (cachedEnvIndex == ENV_MODE_SLIDE) {
      float glideHz = 0.02f + ((float)bpm / 220.0f) * 0.08f;
      voiceCurFreq[i] += (voiceTargetFreq[i] - voiceCurFreq[i]) * glideHz;
      setVoiceFreq(i, voiceCurFreq[i]);
    }

    int16_t sample = 0;
    switch (cachedShape) {
      case 0: { // Square
        sample = oscSqr[i].next();
        break;
      }
      case 1: { // Triangle
        sample = oscTri[i].next();
        break;
      }
      case 2: { // Guitar
        int32_t m = (int32_t)oscTri[i].next() * 120
                  + (int32_t)oscSaw[i].next() * 65
                  + (int32_t)oscCheby[i].next() * 28;
        sample = (int16_t)(m >> 8);
        break;
      }
      case 3: { // Bass
        int32_t m = (int32_t)oscSin[i].next() * 170
                  + (int32_t)oscSqr[i].next() * 90
                  + (int32_t)oscCheby[i].next() * 20;
        sample = (int16_t)(m >> 8);
        break;
      }
      case 4: { // Violin
        int32_t m = (int32_t)oscSaw[i].next() * 100
                  + (int32_t)oscSaw2[i].next() * 92
                  + (int32_t)oscTri[i].next() * 58;
        sample = (int16_t)(m >> 8);
        break;
      }
      case 5: { // TechLead
        int32_t m = (int32_t)oscSaw[i].next() * 118
                  + (int32_t)oscSaw2[i].next() * 102
                  + (int32_t)oscSqr[i].next() * 72;
        sample = (int16_t)(m >> 8);
        break;
      }
      case 6: { // AcidBass
        int32_t m = (int32_t)oscSaw[i].next() * 132
                  + (int32_t)oscSqr[i].next() * 70
                  + (int32_t)oscSin[i].next() * 38;
        sample = (int16_t)(m >> 8);
        break;
      }
      case 7: { // Hybrid
        int32_t m = (int32_t)oscSin[i].next() * 62
                  + (int32_t)oscSaw[i].next() * 78
                  + (int32_t)oscSqr[i].next() * 54
                  + (int32_t)oscTri[i].next() * 46
                  + (int32_t)oscCheby[i].next() * 24;
        sample = (int16_t)(m >> 8);
        break;
      }
      default: sample = oscSin[i].next(); break;
    }

    float envGain = (env / 255.0f) * voiceHoldGain[i];
    mixedSynth += (int32_t)((float)sample * envGain);
    synthActive++;
  }

  // ── Drums synthétisés (Mozzi) ──
  static int16_t hhLast = 0;
  static int32_t clapNoiseLP = 0;
  for (int r = 0; r < DRUM_ROWS; r++) {
    uint8_t denv = drumEnv[r].next();
    if (denv == 0) { drumActive[r] = false; continue; }
    if (!drumActive[r]) continue;

    int16_t ds = 0;
    const DrumBank &bank = drumBanks[currentDrumBank];
    unsigned long elapsed = millis() - drumTrigMs[r];
    switch (r) {
      case 0: // Perc haut (safe) — pas de click violent
        ds = (int16_t)((int32_t)drumSinKick.next() * 115 / 255);
        ds += (int16_t)(nextNoise() * 22);
        ds = (int16_t)((int32_t)ds * 3 / 4);
        break;
      case 1: // Snare — sinus + bruit
        ds = (int16_t)(((int32_t)drumSinSnare.next() * 130 + (int32_t)(nextNoise() * bank.snareNoise)) / 200);
        break;
      case 2: { // HiHat fermé — bruit métallique + tonalité rapide
        int16_t n = (int16_t)(nextNoise() * bank.hhNoise);
        int16_t hp = n - hhLast;
        hhLast = n;
        int16_t tone = (int16_t)((int32_t)drumSinHat.next() * 70 / 255);
        ds = (int16_t)((hp * 2 + tone) / 3);
        break;
      }
      case 3: // Clap — bruit légèrement filtré
        {
          clapNoiseLP = clapNoiseLP * 2 / 3 + nextNoise();
          int32_t burst = (elapsed < 8 || (elapsed >= 18 && elapsed < 26) || (elapsed >= 34 && elapsed < 42)) ? 255 : 130;
          int32_t clap = clapNoiseLP * bank.clapNoise * burst / 255;
          clap += ((int32_t)drumSinClap.next() * 75);
          if (clap > 24000) clap = 24000;
          if (clap < -24000) clap = -24000;
          ds = (int16_t)clap;
        }
        break;
    }
    if (ds > 24000) ds = 24000;
    if (ds < -24000) ds = -24000;
    mixedDrum += ((int32_t)ds * denv) >> 8;
    drumCount++;
  }

  if (drumSampleActive) {
    int16_t s = drumSample.next();
    mixedDrum += (int32_t)s * 18;
    if (!drumSample.isPlaying()) drumSampleActive = false;
  }

  int32_t synthOut = (synthActive > 0) ? (mixedSynth / synthActive) : 0;
  int32_t drumOut = (drumCount > 0) ? (mixedDrum / drumCount) : 0;
  float vscaleForDrumComp = masterVolume / 16000.0f;
  if (vscaleForDrumComp < 1.0f) vscaleForDrumComp = 1.0f;
  if (vscaleForDrumComp > 10.0f) vscaleForDrumComp = 10.0f;

  int32_t drumPost = ((drumOut * drumMixAmount) >> 8);
  // As master volume rises, compensate drum gain so drums do not explode in level.
  float drumComp = drumGlobalGain / (0.80f + 0.20f * vscaleForDrumComp);
  drumPost = (int32_t)((float)drumPost * drumComp);
  if (drumPost > 12000) drumPost = 12000;
  if (drumPost < -12000) drumPost = -12000;

  int32_t mixed = synthOut + drumPost;
  mixed = compress16(mixed, 18000, 2);

  // ── Effets chainables ──
  int16_t output = (int16_t)mixed;
  static int16_t hpfX1 = 0;
  static int16_t hpfY1 = 0;
  static int bcCount = 0;
  static int16_t bcHold = 0;
  fxLfo.setFreq(0.4f + ((float)bpm / 60.0f) * 0.5f);
  flangerLfo.setFreq(0.08f + (float)fxAmount * 0.01f);

  for (int fx = 0; fx < EFFECT_COUNT; fx++) {
    if (!isEffectActive(fx)) continue;
    switch (fx) {
      case 0: {
        // None
        break;
      }
      case 1: {
        uint8_t cutoff = (uint8_t)(18 + ((uint16_t)fxAmount * 180U) / 255U);
        lpf.setCutoffFreq(cutoff);
        output = lpf.next(output);
        break;
      }
      case 2: {
        float cutoff = 25.0f + ((float)fxAmount / 255.0f) * 1800.0f;
        float rc = 1.0f / (6.28318f * cutoff);
        float dt = 1.0f / (float)AUDIO_RATE;
        float a = rc / (rc + dt);
        int16_t y = (int16_t)(a * (hpfY1 + output - hpfX1));
        hpfX1 = output;
        hpfY1 = y;
        output = y;
        break;
      }
      case 3: {
        int delaySamples = constrain((int)((AUDIO_RATE * 60.0f) / (float)bpm / 2.0f), 200, DELAY_BUFFER_SIZE - 1);
        int readIdx = (delayWriteIndex - delaySamples + DELAY_BUFFER_SIZE) % DELAY_BUFFER_SIZE;
        int16_t delayed = delayBuffer[readIdx];
        int fb = 56 + (fxAmount >> 1);
        delayBuffer[delayWriteIndex] = (int16_t)constrain((int)output + ((int)delayed * fb >> 8), -32767, 32767);
        output = (int16_t)((int)output + (((int)delayed * (50 + (fxAmount >> 1))) >> 8));
        break;
      }
      case 4: {
        int delaySamples = constrain((int)((AUDIO_RATE * 60.0f) / (float)bpm * 0.75f), 320, DELAY_BUFFER_SIZE - 1);
        int readIdx = (delayWriteIndex - delaySamples + DELAY_BUFFER_SIZE) % DELAY_BUFFER_SIZE;
        int16_t delayed = delayBuffer[readIdx];
        int16_t filtered = delayed - (delayed >> 3); // slight high-pass flavor
        int fb = 90 + (fxAmount >> 1);
        int wet = 70 + (fxAmount >> 1);
        int32_t wr = (int32_t)output + (((int32_t)filtered * fb) >> 8);
        delayBuffer[delayWriteIndex] = compress16(wr, 22000, 2);
        int32_t mix = (int32_t)output + (((int32_t)filtered * wet) >> 8);
        output = compress16(mix, 24000, 2);
        break;
      }
      case 5: {
        // ResEcho S (safe): compressed feedback path, stable at high FxLv.
        int delaySamples = constrain((int)((AUDIO_RATE * 60.0f) / (float)bpm / 4.0f), 120, DELAY_BUFFER_SIZE - 1);
        int readIdx = (delayWriteIndex - delaySamples + DELAY_BUFFER_SIZE) % DELAY_BUFFER_SIZE;
        int16_t delayed = delayBuffer[readIdx];
        uint16_t centre = 180 + ((uint16_t)fxAmount * 1500U) / 255U;
        uint8_t resonance = (uint8_t)(138 + ((uint16_t)fxAmount * 92U) / 255U);
        resoEchoFilter.setCentreFreq(centre);
        resoEchoFilter.setResonance(resonance);

        int16_t filtered = (int16_t)resoEchoFilter.next(delayed);

        int16_t filteredComp = compress16(filtered, 11000, 2);
        int fb = 102 + ((int)fxAmount * 82) / 255;   // 102..184
        int wet = 74 + ((int)fxAmount * 104) / 255;  // 74..178

        int32_t fbSample = (int32_t)output + (((int32_t)filteredComp * fb) >> 8);
        fbSample = compress16(fbSample, 13500, 2);
        delayBuffer[delayWriteIndex] = (int16_t)fbSample;

        int32_t wetMix = (int32_t)output + (((int32_t)filteredComp * wet) >> 8);
        output = compress16(wetMix, 15000, 2);
        break;
      }
      case 6: {
        // ResEcho R (rich): fuller resonance/feedback with light compression.
        int delaySamples = constrain((int)((AUDIO_RATE * 60.0f) / (float)bpm / 4.0f), 100, DELAY_BUFFER_SIZE - 1);
        int readIdx = (delayWriteIndex - delaySamples + DELAY_BUFFER_SIZE) % DELAY_BUFFER_SIZE;
        int16_t delayed = delayBuffer[readIdx];
        uint16_t centre = 160 + ((uint16_t)fxAmount * 1850U) / 255U;
        uint8_t resonance = (uint8_t)(150 + ((uint16_t)fxAmount * 100U) / 255U);
        resoEchoFilter.setCentreFreq(centre);
        resoEchoFilter.setResonance(resonance);

        int16_t filtered = (int16_t)resoEchoFilter.next(delayed);
        int16_t filteredComp = compress16(filtered, 15000, 3);
        int fb = 120 + ((int)fxAmount * 96) / 255;   // 120..216
        int wet = 86 + ((int)fxAmount * 120) / 255;  // 86..206

        int32_t fbSample = (int32_t)output + (((int32_t)filteredComp * fb) >> 8);
        fbSample = compress16(fbSample, 18000, 3);
        delayBuffer[delayWriteIndex] = (int16_t)fbSample;

        int32_t wetMix = (int32_t)output + (((int32_t)filteredComp * wet) >> 8);
        output = compress16(wetMix, 21000, 3);
        break;
      }
      case 7: {
        // ResEcho X (unbridled): intentionally raw/high feedback flavor.
        int delaySamples = constrain((int)((AUDIO_RATE * 60.0f) / (float)bpm / 4.0f), 90, DELAY_BUFFER_SIZE - 1);
        int readIdx = (delayWriteIndex - delaySamples + DELAY_BUFFER_SIZE) % DELAY_BUFFER_SIZE;
        int16_t delayed = delayBuffer[readIdx];
        uint16_t centre = 140 + ((uint16_t)fxAmount * 2200U) / 255U;
        uint8_t resonance = (uint8_t)(170 + ((uint16_t)fxAmount * 80U) / 255U);
        resoEchoFilter.setCentreFreq(centre);
        resoEchoFilter.setResonance(resonance);

        int16_t filtered = (int16_t)resoEchoFilter.next(delayed);
        int fb = 145 + ((int)fxAmount * 100) / 255;   // 145..245
        int wet = 100 + ((int)fxAmount * 130) / 255;  // 100..230

        int32_t fbSample = (int32_t)output + (((int32_t)filtered * fb) >> 8);
        if (fbSample > 32767) fbSample = 32767;
        if (fbSample < -32767) fbSample = -32767;
        delayBuffer[delayWriteIndex] = (int16_t)fbSample;

        int32_t wetMix = (int32_t)output + (((int32_t)filtered * wet) >> 8);
        if (wetMix > 32767) wetMix = 32767;
        if (wetMix < -32767) wetMix = -32767;
        output = (int16_t)wetMix;
        break;
      }
      case 8: {
        int32_t driveIn = (int32_t)output * (2 + (fxAmount >> 5));
        uint8_t cutoff = (uint8_t)(40 + ((uint16_t)fxAmount * 170U) / 255U);
        uint8_t resonance = (uint8_t)(150 + ((uint16_t)fxAmount * 90U) / 255U);
        uint8_t envPush = (uint8_t)((fxLfo.next() + 128) >> 1);
        acidFilter.setCutoffFreqAndResonance((uint8_t)constrain((int)cutoff + (int)envPush / 4, 0, 255), resonance);
        output = (int16_t)acidFilter.next((int16_t)constrain(driveIn >> 1, -24000, 24000));
        break;
      }
      case 9: {
        int32_t driveIn = (int32_t)output * (2 + (fxAmount >> 5));
        uint8_t cutoff = (uint8_t)(34 + ((uint16_t)fxAmount * 180U) / 255U);
        uint8_t resonance = (uint8_t)(160 + ((uint16_t)fxAmount * 95U) / 255U);
        acidFilter.setCutoffFreqAndResonance(cutoff, resonance);
        int16_t acidOut = (int16_t)acidFilter.next((int16_t)constrain(driveIn >> 1, -26000, 26000));
        int32_t x = (int32_t)acidOut * (int32_t)(2 + (fxAmount >> 6));
        int32_t absx = (x < 0) ? -x : x;
        output = (int16_t)((x * (32767 + absx)) / (32767 + (absx >> 1)));
        break;
      }
      case 10: {
        int base = 28;
        int depth = 52 + (fxAmount >> 1);
        int lfo = (flangerLfo.next() + 128);
        int delaySamples = base + ((lfo * depth) >> 8);
        int readIdx = (delayWriteIndex - delaySamples + DELAY_BUFFER_SIZE) % DELAY_BUFFER_SIZE;
        int16_t delayed = delayBuffer[readIdx];
        int fb = 70 + (fxAmount >> 2);
        int32_t wr = (int32_t)output + (((int32_t)delayed * fb) >> 8);
        delayBuffer[delayWriteIndex] = compress16(wr, 22000, 2);
        int32_t mix = (int32_t)output + (((int32_t)delayed * 150) >> 8);
        output = compress16(mix, 23000, 2);
        break;
      }
      case 11: {
        int32_t x = (int32_t)output * (int32_t)(3 + (fxAmount >> 5));
        if (x > 14000) x = 14000;
        if (x < -14000) x = -14000;
        output = (int16_t)(x * 2);
        break;
      }
      case 12: {
        int hold = 1 + (fxAmount >> 3);
        if (++bcCount >= hold) { bcCount = 0; bcHold = output; }
        output = bcHold;
        break;
      }
      case 13: {
        output = (int16_t)constrain((int)output + random(-(int)fxAmount, (int)fxAmount + 1), -32767, 32767);
        break;
      }
    }
  }

  delayWriteIndex++;
  if (delayWriteIndex >= DELAY_BUFFER_SIZE) delayWriteIndex = 0;

  // ── Volume + saturation sécurisée ──
  float vscale = masterVolume / 16000.0f;
  if (vscale > 10.0f) vscale = 10.0f;
  int32_t driven = (int32_t)((float)output * vscale * 1.5f);
  int32_t absDriven = driven < 0 ? -driven : driven;
  int32_t final32 = (driven * (32767 + (absDriven >> 2))) / (32767 + (absDriven >> 1));
  if (final32 >  32767) final32 =  32767;
  if (final32 < -32767) final32 = -32767;
  int16_t finalSample = (int16_t)final32;

  return MonoOutput::from16Bit(finalSample);
}

// ============================================================
//  SETUP
// ============================================================
void setup() {
  Serial.begin(115200);
  analogReadResolution(12);

  // I2S
  i2s.setPins(I2S_BCLK, I2S_LRC, I2S_DIN);
  if (!i2s.begin(I2S_MODE_STD, SAMPLE_RATE_HZ, I2S_DATA_BIT_WIDTH_16BIT, I2S_SLOT_MODE_STEREO)) {
    Serial.println("[BOOT] I2S init failed!");
    while (1);
  }

  // NeoPixel
  strip.begin();
  strip.setBrightness(BRIGHTNESS);
  strip.show();
  columnColors[0] = strip.Color(255,   0,   0);
  columnColors[1] = strip.Color(255, 127,   0);
  columnColors[2] = strip.Color(255, 255,   0);
  columnColors[3] = strip.Color(  0, 255,   0);
  columnColors[4] = strip.Color(  0, 255, 255);
  columnColors[5] = strip.Color(  0,   0, 255);
  columnColors[6] = strip.Color(127,   0, 255);
  columnColors[7] = strip.Color(255,   0, 127);

  // OLED (Wire sur SDA=26 SCL=27)
  Wire.begin(OLED_SDA, OLED_SCL, 400000);
  Wire.setClock(400000);
  Wire.setTimeOut(20);
  delay(20);
  u8g2.begin();
  u8g2.setFont(u8g2_font_6x12_tf);
  u8g2.clearBuffer();
  u8g2.drawFrame(0, 0, 128, 128);
  u8g2.drawStr(20, 40, "CLAVIER V2");
  u8g2.drawStr(10, 58, "Mozzi synth");
  u8g2.drawStr(10, 74, "drum engine");
  u8g2.sendBuffer();
  delay(600);

  // MCP23X17 (TwoWire 1 sur SDA=21 SCL=22)
  buttonsWire.begin(I2C_SDA, I2C_SCL, 400000);
  buttonsWire.setTimeOut(20);
  if (!mcp1.begin_I2C(0x21, &buttonsWire))    { Serial.println("[BOOT] MCP1 fail");     while (1); }
  if (!mcp2.begin_I2C(0x23, &buttonsWire))    { Serial.println("[BOOT] MCP2 fail");     while (1); }
  if (!mcpExtra.begin_I2C(0x26, &buttonsWire)){ Serial.println("[BOOT] MCPExtra fail"); while (1); }
  for (int i = 0; i < 16; i++) {
    mcp1.pinMode(i, INPUT_PULLUP);
    mcp2.pinMode(i, INPUT_PULLUP);
  }
  for (int i = 0; i < EXTRA_BUTTONS; i++) {
    mcpExtra.pinMode(extraMcpPins[i], INPUT_PULLUP);
  }
  scanButtons();
  consumeButtonEvents();

  // Voix synth
  for (int i = 0; i < VOICE_COUNT; i++) {
    oscSin[i].setTable(SIN2048_DATA);
    oscSaw[i].setTable(SAW2048_DATA);
    oscSaw2[i].setTable(SAW2048_DATA);
    oscSqr[i].setTable(SQUARE_NO_ALIAS_2048_DATA);
    oscTri[i].setTable(TRIANGLE2048_DATA);
    oscCheby[i].setTable(CHEBYSHEV_3RD_256_DATA);
    voices[i] = {false, false, 0, 440.0f};
    setVoiceFreq(i, 440.0f);
    envelope[i].setADLevels(255, 220);
    envelope[i].setTimes(10, 50, 600000, 200);
  }

  // Drums synth
  drumSinKick.setTable(SIN2048_DATA);
  drumSinSnare.setTable(SIN2048_DATA);
  drumSinHat.setTable(SIN2048_DATA);
  drumSinClap.setTable(SIN2048_DATA);
  drumSinKick.setFreq(80.0f);
  drumSinSnare.setFreq(200.0f);
  drumSinHat.setFreq(2400.0f);
  drumSinClap.setFreq(1600.0f);
  drumSample.setFreq((float)BURROUGHS1_18649_SAMPLERATE / (float)BURROUGHS1_18649_NUM_CELLS);
  for (int r = 0; r < DRUM_ROWS; r++) {
    drumEnv[r].setADLevels(255, 0);
    drumEnv[r].setTimes(2, 60, 0, 80);
    drumActive[r] = false;
  }

  // Lecture initiale des pots
  for (int i = 0; i < 5; i++) {
    int initFallback = (i == 4) ? 2048 : 0;
    //potFilt[i] = safeAnalogReadPin(POT_PINS[i], initFallback);
    potRaw[i] = analogRead(POT_PINS[i]);
    potFilt[i] = invertPotValue(potRaw[i]);
    
  }
  octaveStable = quantizeOctaveFromPot(potFilt[4]);
  octaveShift = octaveStable;
  lastOctaveShift = octaveShift;
  masterVolume = 180000.0f;
  tetrisSpawnPiece();

  xTaskCreatePinnedToCore(
    buttonScanTask,
    "buttonScan",
    4096,
    nullptr,
    1,
    &buttonScanTaskHandle,
    0
  );

  xTaskCreatePinnedToCore(
    uiTask,
    "uiTask",
    6144,
    nullptr,
    1,
    &uiTaskHandle,
    0
  );

  startMozzi(CONTROL_RATE);
  Serial.println("[BOOT] Clavier V2 — Mozzi synth + drum engine ready");
}

// ============================================================
//  LOOP
// ============================================================
void loop() {
  consumeButtonEvents();
  processInputActions();

  // L'audio passe juste apres le traitement d'entree pour reduire au maximum
  // le delai entre appui et noteOn.
  audioHook();  // Mozzi gère tout (updateControl + updateAudio)
}
