// LFSR 32-bit pour le bruit
static uint32_t lfsrState = 0xACE1FACE;
static inline int8_t nextNoise() {
  lfsrState ^= lfsrState << 13;
  lfsrState ^= lfsrState >> 17;
  lfsrState ^= lfsrState << 5;
  return (int8_t)(lfsrState & 0xFF);
}

