// ============================================================
// clavier_v2.ino
// Poly synth + drum sequencer
// Inspiré de mini_instru_v2_3 (Mozzi engine)
// Hardware : ESP32, MCP23X17, NeoPixel, SH1107 128x128, I2S DAC
// Audio    : Mozzi ADSR + 12 formes d'ondes + 6 effets + arpégiateur
// Drums    : synthèse Mozzi (oscillateurs + LFSR) — sans .h PCM manuel
// ============================================================

#include <Arduino.h>

// Keep I2S and Mozzi at the same sample rate to avoid pitch shift and artifacts.
#define SAMPLE_RATE_HZ  16384

// ==================== MOZZI CONFIG ====================
#define MOZZI_AUDIO_MODE MOZZI_OUTPUT_EXTERNAL_TIMED
#define MOZZI_AUDIO_RATE SAMPLE_RATE_HZ
#define CONTROL_RATE 256

